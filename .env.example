# LangChain LLM Toolkit 环境变量配置示例
# 复制此文件为 .env 并填入您的实际配置

# ===========================================
# OpenAI API 配置
# ===========================================
# 获取 API 密钥: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI API 基础 URL（可选，用于代理或自定义端点）
# OPENAI_API_BASE=https://api.openai.com/v1

# ===========================================
# Anthropic API 配置
# ===========================================
# 获取 API 密钥: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ===========================================
# Google AI API 配置
# ===========================================
# 获取 API 密钥: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# ===========================================
# Ollama 本地模型配置
# ===========================================
# Ollama 服务地址（默认为本地）
OLLAMA_BASE_URL=http://localhost:11434

# Ollama 默认模型
OLLAMA_DEFAULT_MODEL=llama3

# ===========================================
# 默认模型配置
# ===========================================
# 默认使用的模型
# 可选值: gpt-4o, gpt-4, gpt-3.5-turbo, claude-3-opus, claude-3-sonnet, gemini-pro, ollama/llama3
DEFAULT_MODEL=gpt-4o

# 默认温度参数（0.0-2.0，越高越随机）
DEFAULT_TEMPERATURE=0.7

# 默认最大令牌数
DEFAULT_MAX_TOKENS=2000

# ===========================================
# 应用配置
# ===========================================
# 应用名称
APP_NAME=LangChain LLM Toolkit

# 应用环境（development, production, testing）
APP_ENV=development

# 调试模式（True/False）
DEBUG=True

# 日志级别（DEBUG, INFO, WARNING, ERROR, CRITICAL）
LOG_LEVEL=INFO

# ===========================================
# API 服务配置
# ===========================================
# API 服务主机
API_HOST=0.0.0.0

# API 服务端口
API_PORT=8000

# API 工作进程数（生产环境建议设置为 CPU 核心数）
API_WORKERS=1

# ===========================================
# Web 界面配置
# ===========================================
# Web 服务端口
WEB_PORT=8501

# ===========================================
# RAG 配置
# ===========================================
# 向量存储类型（faiss, qdrant）
VECTOR_STORE_TYPE=faiss

# 向量存储路径
VECTOR_STORE_PATH=./vector_store

# 文档块大小（字符数）
CHUNK_SIZE=1000

# 文档块重叠大小（字符数）
CHUNK_OVERLAP=200

# 检索文档数量
RETRIEVAL_K=3

# ===========================================
# Qdrant 向量数据库配置（如果使用 Qdrant）
# ===========================================
# Qdrant 服务地址
QDRANT_URL=http://localhost:6333

# Qdrant API 密钥（如果需要）
# QDRANT_API_KEY=your_qdrant_api_key

# Qdrant 集合名称
QDRANT_COLLECTION_NAME=langchain_documents

# ===========================================
# Embedding 模型配置
# ===========================================
# Embedding 模型类型（openai, huggingface, local）
EMBEDDING_TYPE=openai

# Hugging Face 模型名称（如果使用 Hugging Face）
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ===========================================
# 性能配置
# ===========================================
# 请求超时时间（秒）
REQUEST_TIMEOUT=30

# 最大重试次数
MAX_RETRIES=3

# 重试延迟（秒）
RETRY_DELAY=1

# ===========================================
# 安全配置
# ===========================================
# API 密钥加密密钥（用于加密存储的密钥）
# SECRET_KEY=your_secret_key_here

# 允许的来源（CORS）
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ===========================================
# 缓存配置
# ===========================================
# 是否启用缓存
ENABLE_CACHE=True

# 缓存类型（memory, redis）
CACHE_TYPE=memory

# Redis URL（如果使用 Redis）
# REDIS_URL=redis://localhost:6379/0

# ===========================================
# 监控配置
# ===========================================
# 是否启用监控
ENABLE_MONITORING=False

# 监控服务地址
# MONITORING_URL=http://localhost:9090

# ===========================================
# 开发配置
# ===========================================
# 是否启用开发模式
DEV_MODE=True

# 是否启用热重载
HOT_RELOAD=True

# ===========================================
# 测试配置
# ===========================================
# 测试环境标志
TESTING=False

# 测试数据库 URL
# TEST_DATABASE_URL=sqlite:///./test.db
