# ===========================================
# LangChain LLM Toolkit — 环境变量配置
# 复制为 .env 并填入实际值
# ===========================================

# --- LLM API Keys ---
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# HUGGINGFACE_API_KEY=

# --- OpenAI-Compatible (Agnes / DeepSeek 等) ---
# OPENAI_API_BASE=https://apihub.agnes-ai.com/v1

# --- Ollama (本地) ---
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=gemma4

# --- 默认模型 ---
# 可选: deepseek-chat, gpt-4o, agnes-2.0-flash, ollama/gemma4 等
DEFAULT_MODEL=deepseek-chat
DEFAULT_TEMPERATURE=0.7

# --- RAG ---
VECTOR_STORE_TYPE=qdrant
RAG_QDRANT_PATH=./qdrant_storage
RAG_FAISS_PATH=./vector_store
RAG_COLLECTION_NAME=langchain_documents

# --- 应用 ---
# APP_NAME=LangChain LLM Toolkit
# DEBUG=False

# --- 可选: 认证 / 持久化 ---
# INTERNAL_API_KEY=
# JWT_SECRET_KEY=
# CONVERSATION_DB_PATH=./data/conversations.db
# AUTH_DB_PATH=./data/auth.db
# QDRANT_URL=
# QDRANT_API_KEY=
